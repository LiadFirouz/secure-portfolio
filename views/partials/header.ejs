<style>
  /* הגדרת הכפתורים הכללית */
  .custom-nav-link {
    color: #333;
    background-color: transparent;
    padding: 10px 20px;
    margin: 0 5px;
    border-radius: 5px;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.3s ease;
    border: 1px solid transparent;
  }

  .custom-text {
    color: #333;
    padding: 0px 20px;
    margin: 0 5px;
    font-weight: 500;
  }


  .custom-nav-link:not(.active-page):hover {
    background-color: #000;
    color: #fff;
  }

  /* מצב פעיל (הדף הנוכחי) - כחול ובולט */
  .custom-nav-link.active-page {
    color: #0d6efd;
    font-weight: 700;
    /* מונע מהעכבר להציג סמן של לחיצה ומונע אינטראקציה */
    cursor: default; 
  }
</style>

<header class="d-flex justify-content-between align-items-center py-3 mb-4 border-bottom">
  <h3 class="custom-text">
    <span class="fs-2">LF &nbsp;</span>
  </h3>

  <nav class="nav">
    <a href="/" class="custom-nav-link <%= activePage === 'home' ? 'active-page' : '' %>">Home</a>
    <a href="/about" class="custom-nav-link <%= activePage === 'about' ? 'active-page' : '' %>">About</a>
    <a href="/cv" class="custom-nav-link <%= activePage === 'cv' ? 'active-page' : '' %>">CV</a>
  </nav>
</header>