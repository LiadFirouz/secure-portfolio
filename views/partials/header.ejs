<style>
  /* Navigation Link Base Style */
  .custom-nav-link {
    color: #333;
    background-color: transparent;
    padding: 10px 20px;
    margin: 0 5px;
    border-radius: 5px;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.3s ease;
    border: 1px solid transparent;
  }

  /* Hover Effect: Exclude active page */
  .custom-nav-link:not(.active-page):hover {
    background-color: #000;
    color: #fff;
  }

  /* Active Page: Blue and non-interactive */
  .custom-nav-link.active-page {
    color: #0d6efd;
    font-weight: 700;
    cursor: default;
  }

  /* Branding Text */
  .custom-brand {
    color: #333;
    margin: 0;
    padding: 0 10px;
    font-weight: 700;
    font-size: 1.5rem;
  }
</style>

<header class="d-flex justify-content-between align-items-center py-3 mb-4 border-bottom">
  <h3 class="custom-brand">LF</h3>

  <nav class="nav">
    <a href="/" class="custom-nav-link <%= activePage === 'home' ? 'active-page' : '' %>">Home</a>
    <a href="/about" class="custom-nav-link <%= activePage === 'about' ? 'active-page' : '' %>">About</a>
    <a href="/cv" class="custom-nav-link <%= activePage === 'cv' ? 'active-page' : '' %>">CV</a>
  </nav>
</header>