<!DOCTYPE html>
<html lang="en" data-bs-theme="light">

<head>
    <title>Liad Firouz - Portfolio</title>
    <%- include('partials/head') %>

        <style>
            /* Container Layouts */
            .main-content {
                min-height: 300px;
                height: auto;
            }

            .black-banner {
                background-color: black;
                color: white;
            }

            .hero-banner {
                height: 300px;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
            }

            /* Profile Image */
            .profile-img {
                width: 150px;
                height: 150px;
                object-fit: cover;
                border-radius: 50%;
                border: 4px solid #000;
            }

            /* Cards & Components */
            .card {
                height: 100%;
                transition: transform 0.2s;
            }

            .card-img-top {
                object-fit: cover;
                height: 225px;
            }

            .icon-square {
                height: 30px;
            }

            .quote-text {
                color: rgb(255, 255, 255);
            }

            /* General Button Styles */
            .custom-btn {
                transition: all 0.3s ease;
                /* Black text for default state */
                color: #000;
            }

            /* Hover state for all buttons (Black background with white text) */
            .custom-btn:hover {
                background-color: #000;
                color: #fff;
            }

            /* Specific style for CV button (Blue) */
            .cv-btn {
                color: #0d6efd;
            }

            /* Hover state for CV button (Blue background with white text) */
            .cv-btn:hover {
                background-color: #0d6efd;
                color: #fff;
            }

            .custom-btn,
            .cv-btn {
                display: inline-flex !important;
                justify-content: center !important;
                align-items: center !important;
                text-align: center !important;
            }

            /* Modern Card Styling */
            .project-card {
                border-radius: 16px !important;
                /* Rounded corners */
                overflow: hidden;
                /* Clip image to match the card's rounded corners */
                transition: transform 0.3s ease, box-shadow 0.3s ease;
            }

            /* Hover effect for project cards */
            .project-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15) !important;
            }

            /* Technology tags styling */
            .badge-tech {
                background: #f0f2f5;
                color: #444;
                font-size: 0.75rem;
                padding: 5px 12px;
                border-radius: 20px;
                margin-right: 5px;
                font-weight: 600;
            }

            /* Modern Section Title */
            .section-title-wrapper {
                text-align: center;
                padding: 5rem 0 3rem;
                position: relative;
            }

            .tech-badge-title {
                display: inline-block;
                font-family: monospace;
                color: #0d6efd;
                padding: 0.3rem 1rem;
                border-radius: 50px;
                font-weight: 700;
                letter-spacing: 1.5px;
                margin-bottom: 1rem;
                text-transform: uppercase;
            }

            .gradient-title {
                font-size: 1.4rem;
                font-weight: 800;
                /* Gradient transition from black to blue */
                background: linear-gradient(135deg, #000000 0%, #333333 40%, #0d6efd 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                margin-bottom: 1rem;
                letter-spacing: -1px;
            }



            /* Elevated Contact Button */
            .contact-btn {
                transition: transform 0.3s ease, box-shadow 0.3s ease;
                border-radius: 50px;
                padding: 0.8rem 2.5rem;
            }

            .contact-btn:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 20px rgba(13, 110, 253, 0.2);
            }
        </style>
</head>

<body>

    <%- include('partials/header') %>

        <main style="height: auto; min-height: 300px;">
            <div class="d-flex flex-column align-items-center py-5 px-3">

                <div class="container text-center mb-4">
                    <img src="/src/profile.jpeg" alt="Liad Firouz" class="profile-img" />
                </div>

                <h1 class="text-center">Hello, I'm Liad Firouz ;)</h1>

                <p class="lead text-center fw-medium mt-2">
                    ⧼ B.Sc. Computer Science Student | Cyber Security Specialization & Software Development ⧽
                </p>

                <div class="d-flex justify-content-center align-items-center mt-3 gap-3">
                    <a href="/about" class="btn btn-lg fw-bold custom-btn">About Me</a>
                    <a href="/cv" class="btn btn-lg fw-bold custom-btn cv-btn">View My CV</a>
                    <a href="#projects" class="btn btn-lg fw-bold custom-btn">View My Projects</a>
                </div>

            </div>
        </main>

        <div style="background-color: black; color: white;">
            <div class="container px-4 py-5" id="hanging-icons">
                <div
                    class="row g-4 py-5 row-cols-1 row-cols-lg-3 row-cols-md-3 row-cols-sm-2 d-flex justify-content-center">

                    <div class="col d-flex justify-content-center">
                        <div class="icon-square d-inline-flex fs-4 me-3">
                            <img src="/home-images/cpu.png" alt="Tech Stack" height="30px">
                        </div>
                        <div>
                            <h3 class="fs-2">Tech Stack</h3>
                            <p>C, JavaScript, Python</p>
                            <p>Java, C#, SQL</p>
                        </div>
                    </div>

                    <div class="col d-flex justify-content-center">
                        <div class="icon-square d-inline-flex fs-4 me-3">
                            <img src="/home-images/framework.png" alt="Frameworks" height="30px">
                        </div>
                        <div>
                            <h3 class="fs-2">Tools & Env</h3>
                            <p>Node.js, Express.js</p>
                            <p>Git, Linux</p>
                            <p>Bootstrap, VS Code</p>
                        </div>
                    </div>

                    <div class="col d-flex justify-content-center">
                        <div class="icon-square d-inline-flex me-3">
                            <img src="/home-images/check.png" alt="Qualities" height="30px">
                        </div>
                        <div>
                            <h3 class="fs-2">Soft Skills</h3>
                            <p>Analytical Thinker</p>
                            <p>Self-learner</p>
                            <p>Team player</p>
                            <p>Adaptable & Motivated</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="album bg-body-tertiary">
            <div class="container pb-5">
                <div class="section-title-wrapper" id="projects">
                    <h1 class="tech-badge-title">&lt;/&gt; Portfolio</h1>
                    <h1 class="gradient-title">Featured Projects</h1>
                    <div class="title-accent-line"></div>
                </div>
                <div class="row row-cols-1 row-cols-md-3 g-4">
                    <div class="col">
                        <div class="card project-card shadow-sm h-100">
                            <div class="bg-dark text-white d-flex align-items-center justify-content-center"
                                style="height: 200px;">
                                <span class="fs-4 fw-bold">Assembler</span>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <span class="badge-tech">C</span><span class="badge-tech">Systems</span>
                                </div>
                                <h5 class="fw-bold">Custom Assembler</h5>
                                <p class="card-text text-muted small">A robust, two-pass assembler built in C featuring
                                    dynamic memory allocation and bitwise logic.</p>
                                <div class="d-flex gap-2 mt-3">
                                    <a href="/projects/assembler" class="btn btn-dark btn-sm rounded-pill px-3">View
                                        Details</a>
                                    <a href="https://github.com/LiadFirouz/Assembler" target="_blank"
                                        class="btn btn-outline-secondary btn-sm rounded-pill px-3">GitHub</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col">
                        <div class="card project-card shadow-sm h-100">
                            <img src="/home-images/Stock-Predictor-img.png" class="card-img-top"
                                style="height: 200px; object-fit: cover;">
                            <div class="card-body">
                                <div class="mb-3">
                                    <span class="badge-tech">Python</span><span class="badge-tech">ML</span>
                                </div>
                                <h5 class="fw-bold">Stock Prediction</h5>
                                <p class="card-text text-muted small">Machine learning model built with Python to
                                    analyze market trends and historical financial data.</p>
                                <div class="d-flex gap-2 mt-3">
                                    <a href="/projects/stock-predictor"
                                        class="btn btn-dark btn-sm rounded-pill px-3">View Details</a>
                                    <a href="https://github.com/LiadFirouz/StockPricePrediction" target="_blank"
                                        class="btn btn-outline-secondary btn-sm rounded-pill px-3">GitHub</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col">
                        <div class="card project-card shadow-sm h-100">
                            <img src="/home-images/simon-game-img.png" class="card-img-top"
                                style="height: 200px; object-fit: cover;">
                            <div class="card-body">
                                <div class="mb-3">
                                    <span class="badge-tech">JavaScript</span><span class="badge-tech">DOM</span>
                                </div>
                                <h5 class="fw-bold">Simon Game</h5>
                                <p class="card-text text-muted small">Interactive memory game demonstrating asynchronous
                                    JavaScript logic and DOM manipulation.</p>
                                <div class="d-flex gap-2 mt-3">
                                    <a href="/projects/simon-game" class="btn btn-dark btn-sm rounded-pill px-3">View
                                        Details</a>
                                    <a href="https://liadfirouz.github.io/Simon-Game/" target="_blank"
                                        class="btn btn-outline-secondary btn-sm rounded-pill px-3">GitHub</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <div class="py-4 w-100 bg-body-tertiary">
            <div class="container my-5">
                <div class="text-center">
                    <h2 class="fw-bold mb-3">Let's Build Something Together</h2>
                    <p class="lead text-muted mb-4">I'm actively seeking opportunities in Software Development and Cyber
                        Security.</p>
                    <a href="mailto:liad.firouz@gmail.com" class="btn btn-primary btn-lg fw-bold contact-btn">Get In
                        Touch</a>
                </div>
            </div>
        </div>

        <div class="container">
            <%- include('partials/footer') %>
        </div>

</body>

</html>